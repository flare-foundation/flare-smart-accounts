{
  "name": "flare-smart-accounts",
  "version": "1.0.0",
  "description": "Smart contracts implementing Flare Smart Accounts.",
  "main": "",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/flarenetwork/smart-accounts/flare-smart-accounts.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Flare SC team",
  "license": "MIT",
  "directories": {},
  "scripts": {
    "build": "forge build",
    "---------TEST---SCRIPTS": "",
    "test": "forge test -vvv",
    "coverage": "forge coverage --report lcov && node scripts/forge-lcov-prune.js && genhtml lcov.info.pruned --branch-coverage --output-dir coverage",
    "---------DEPLOY---SCRIPTS": "",
    "deploy_contracts": "bash deployment/scripts/deploy-smart-accounts.sh",
    "deploy_personal_account_implementation": "bash deployment/scripts/deploy-personal-account-implementation.sh",
    "deploy_my_erc4626_coston2": "dotenv -e .env -- sh -c 'forge script deployment/scripts/DeployMyERC4626.s.sol:DeployMyERC4626 --rpc-url $COSTON2_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast'",
    "diamond_cut": "bash deployment/scripts/execute-diamond-cut.sh",
    "---------LINTER---SCRIPTS": "",
    "lint:check": "eslint \"{deployment,scripts}/**/*.ts\"",
    "lint:fix": "eslint \"{deployment,scripts}/**/*.ts\" --fix",
    "format:check": "prettier --check \"{deployment,scripts}/**/*.{ts,js}\"",
    "format:fix": "prettier --write \"{deployment,scripts}/**/*.{ts,js}\"",
    "lint-sol": "pnpm lint-sol-contracts && pnpm lint-sol-test && pnpm lint-sol-deployment",
    "lint-sol-contracts": "solhint \"contracts/**/*.sol\"",
    "lint-sol-test": "solhint \"test/**/*.sol\"",
    "lint-sol-deployment": "solhint \"deployment/**/*.sol\"",
    "slither": "pip3 install slither-analyzer && rm -f ./slither.json && rm -f ./slither_badge.json 2> /dev/null; slither . --filter-paths \"dependencies|node_modules|mock\" --json=./slither.json 2> /dev/null || true; node scripts/slither-parse.js ./slither.json",
    "---------OTHER---SCRIPTS": "",
    "get-error-selectors": "bash scripts/extract-error-selectors.sh",
    "verify_contracts": "tsx deployment/scripts/verify-contracts.ts"
  },
  "devDependencies": {
    "@coverage.rocks/genhtml": "^1.16.0",
    "@eslint/compat": "^2.0.0",
    "@flarenetwork/eslint-config-flare": "^0.0.2",
    "@flarenetwork/prettier-config-flare": "^0.0.3",
    "dotenv-cli": "^7.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.1.0",
    "solhint": "^6.0.1",
    "solidity-coverage": "^0.8.11",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "web3": "^4.0.0"
  },
  "prettier": "@flarenetwork/prettier-config-flare",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}

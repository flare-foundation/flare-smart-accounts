{
  "name": "flare-smart-accounts",
  "version": "1.0.0",
  "description": "Smart contracts implementing Flare Smart Accounts.",
  "main": "",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/flarenetwork/smart-accounts/flare-smart-accounts.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Flare SC team",
  "license": "MIT",
  "directories": {},
  "scripts": {
    "build": "forge build",
    "---------TEST---SCRIPTS": "",
    "test": "forge test -vvv",
    "coverage": "forge coverage --report lcov && node scripts/forge-lcov-prune.js && genhtml lcov.info.pruned --branch-coverage --output-dir coverage",
    "---------DEPLOY---SCRIPTS": "",
    "deploy_contracts": "bash deployment/scripts/deploy-smart-accounts.sh",
    "deploy_personal_account_implementation": "bash deployment/scripts/deploy-personal-account-implementation.sh",
    "deploy_my_erc4626_coston2": "dotenv -e .env -- sh -c 'forge script deployment/scripts/DeployMyERC4626.s.sol:DeployMyERC4626 --rpc-url $COSTON2_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast'",
    "diamond_cut": "bash deployment/scripts/execute-diamond-cut.sh",
    "---------LINTER---SCRIPTS": "",
    "lint:check": "eslint \"{deployment,scripts}/**/*.ts\"",
    "lint:fix": "eslint \"{deployment,scripts}/**/*.ts\" --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint-sol": "yarn lint-sol-contracts && yarn lint-sol-test && yarn lint-sol-deployment",
    "lint-sol-contracts": "yarn solhint \"contracts/**/*.sol\"",
    "lint-sol-test": "yarn solhint \"test/**/*.sol\"",
    "lint-sol-deployment": "yarn solhint \"deployment/**/*.sol\"",
    "slither": "pip3 install slither-analyzer && rm -f ./slither.json && rm -f ./slither_badge.json 2> /dev/null; slither . --json=./slither.json 2> /dev/null || true; node scripts/slither-parse.js ./slither.json",
    "---------OTHER---SCRIPTS": "",
    "get-error-selectors": "bash scripts/extract-error-selectors.sh",
    "verify_contracts": "ts-node deployment/scripts/verify-contracts.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@coverage.rocks/genhtml": "^1.16.0",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.0",
    "dotenv-cli": "^7.0.0",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.1.0",
    "solhint": "^6.0.1",
    "solidity-coverage": "^0.8.11",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.48.0",
    "web3": "^4.0.0"
  }
}
